---
import { getCollection } from 'astro:content';
import DevlogPost from '@components/pages/DevlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('devlog', ({ data }) => data.locale === 'pt');
  return posts.map((post) => {
    const slug = post.id.slice(0, -(post.data.locale.length));
    return {
      params: { slug },
      props: { post, slug },
    };
  });
}

const { post, slug } = Astro.props;
---
<DevlogPost locale="pt" post={post} slug={slug} />
