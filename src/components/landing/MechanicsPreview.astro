---
import type { Locale } from '@i18n/utils';
import { t, getUrl } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);

const cards = [
  {
    icon: '◇',
    title: strings.landing.rulesCardTitle,
    body: locale === 'pt'
      ? 'De padrões numéricos a desafios baseados em tempo. Cada zona traz um novo conjunto de regras, e nunca te diz qual é.'
      : locale === 'es'
      ? 'De patrones numéricos a desafíos basados en el tiempo. Cada zona trae un nuevo conjunto de reglas, y nunca te dice cuál es.'
      : 'From numeric patterns to time-based challenges. Each zone brings a new rule set, and never tells you what it is.',
  },
  {
    icon: '◆',
    title: strings.landing.skillsCardTitle,
    body: locale === 'pt'
      ? 'Habilidades opcionais que ajudam sem resolver por você. O puzzle ainda é seu.'
      : locale === 'es'
      ? 'Habilidades opcionales que ayudan sin resolver el puzzle por ti. El puzzle sigue siendo tuyo.'
      : 'Optional abilities that help without solving it for you. The puzzle is still yours.',
  },
  {
    icon: '▣',
    title: strings.landing.zonesCardTitle,
    body: locale === 'pt'
      ? 'Dez zonas distintas, cada uma com visual e regras próprias. Mais profundidade do que parece à primeira vista.'
      : locale === 'es'
      ? 'Diez zonas distintas, cada una con su propio estilo visual y reglas. Más profundidad de lo que parece a primera vista.'
      : 'Ten distinct zones with their own visual style and rule set. More depth than it first appears.',
  },
];
---
<section class="mechanics-preview section section-alt">
  <div class="container">
    <h2 class="mechanics-preview__title">{strings.landing.mechanicsTitle}</h2>

    <div class="mechanics-preview__grid">
      {cards.map((card) => (
        <article class="mechanic-card">
          <span class="mechanic-card__icon" aria-hidden="true">{card.icon}</span>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>

    <div class="mechanics-preview__link">
      <a href={getUrl('mechanics', locale)}>
        {strings.landing.mechanicsLink} →
      </a>
    </div>
  </div>
</section>

<style>
  .mechanics-preview__title {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .mechanics-preview__grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .mechanics-preview__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mechanic-card {
    background-color: var(--color-bg);
    border: var(--border-width) solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color var(--transition-fast),
                box-shadow var(--transition-normal);
  }

  .mechanic-card:hover {
    border-color: var(--color-brand);
    box-shadow: var(--shadow-sm);
  }

  .mechanic-card__icon {
    font-size: 2rem;
    color: var(--color-accent);
    line-height: 1;
  }

  .mechanic-card h3 {
    color: var(--color-text);
  }

  .mechanic-card p {
    color: var(--color-text-muted);
    font-size: var(--text-body);
  }

  .mechanics-preview__link {
    text-align: center;
    margin-top: var(--space-8);
  }

  .mechanics-preview__link a {
    font-family: var(--font-heading);
    font-weight: var(--weight-bold);
    color: var(--color-brand);
    transition: color var(--transition-fast);
  }

  .mechanics-preview__link a:hover {
    color: var(--color-brand-hover);
  }
</style>
