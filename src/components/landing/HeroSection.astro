---
import type { Locale } from '@i18n/utils';
import { t } from '@i18n/utils';
import CTASteam from '@components/ui/CTASteam.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
---
<section class="hero">
  <div class="container">
    <div class="hero__banner">
      <img
        src="/images/screenshot-hero.png"
        alt="Don't Step Wrong 2 — gameplay screenshot"
        width="1200"
        height="675"
        class="screenshot-hero hero__image"
        loading="eager"
        decoding="async"
      />
      <div class="hero__copy">
        <h1>{strings.landing.heroTitle}</h1>
        <p class="hero__lead">{strings.landing.heroLead}</p>
        <div class="hero__ctas">
          <CTASteam label={strings.cta.playDemo} target="demo" variant="primary" />
          <CTASteam label={strings.cta.addToWishlist} target="wishlist" variant="ghost" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-section);
  }

  .hero__banner {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .hero__image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-lg);
    /* Filtro warm para harmonizar com a paleta creme/âmbar do site */
    filter: sepia(18%) saturate(82%) hue-rotate(8deg) brightness(0.9);
  }

  /* Gradiente esquerda → direita: bg sólido → transparente */
  .hero__banner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--color-bg) 0%,
      var(--color-bg) 18%,
      rgba(254, 251, 246, 0.90) 34%,
      rgba(254, 251, 246, 0.28) 56%,
      transparent 72%
    );
    pointer-events: none;
  }

  /* Copy sobreposta na metade esquerda da imagem */
  .hero__copy {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 56%;
    max-width: 580px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-6);
    padding: var(--space-8);
    z-index: 1;
  }

  .hero__lead {
    font-size: var(--text-lead);
    color: var(--color-text-muted);
    max-width: 30ch;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  /* Mobile: copy empilha abaixo da imagem */
  @media (max-width: 767px) {
    .hero__banner {
      overflow: visible;
      border-radius: 0;
    }

    .hero__banner::after {
      display: none;
    }

    .hero__image {
      border-radius: var(--radius-lg);
      filter: none;
    }

    .hero__copy {
      position: static;
      width: 100%;
      max-width: none;
      padding: var(--space-6) 0 0;
    }

    .hero__lead {
      max-width: none;
    }
  }
</style>
