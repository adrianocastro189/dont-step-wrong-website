---
import type { Locale } from '@i18n/utils';
import { t } from '@i18n/utils';
import CTASteam from '@components/ui/CTASteam.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
---
<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <h1>{strings.landing.heroTitle}</h1>
      <p class="hero__lead">{strings.landing.heroLead}</p>
      <div class="hero__ctas">
        <CTASteam label={strings.cta.playDemo} target="demo" variant="primary" />
        <CTASteam label={strings.cta.addToWishlist} target="wishlist" variant="ghost" />
      </div>
    </div>

    <div class="hero__visual">
      <img
        src="/images/screenshot-hero.png"
        alt="Don't Step Wrong 2 — gameplay screenshot"
        width="1200"
        height="675"
        class="screenshot-hero"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-section);
    position: relative;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    gap: var(--space-12);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .hero__lead {
    font-size: var(--text-lead);
    color: var(--color-text-muted);
    max-width: 30ch;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  /* Mobile: imagem em fluxo normal */
  .hero__visual {
    display: flex;
    justify-content: center;
  }

  .screenshot-hero {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-lg);
  }

  /* Desktop: grid 2 colunas — copy esquerda, imagem direita full-height com fade */
  @media (min-width: 1024px) {
    .hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-8);
      align-items: stretch;
    }

    .hero__copy {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero__visual {
      position: relative;
      display: block;
    }

    .hero__visual::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, var(--color-bg) 0%, transparent 45%);
      z-index: 1;
      pointer-events: none;
    }

    .screenshot-hero {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      border-radius: 0;
    }
  }
</style>
