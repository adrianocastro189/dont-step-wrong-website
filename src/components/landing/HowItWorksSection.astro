---
import type { Locale } from '@i18n/utils';
import { t } from '@i18n/utils';
import Placeholder from '@components/ui/Placeholder.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
---
<section class="how-it-works section">
  <div class="container">
    <h2 class="how-it-works__title">{strings.landing.howItWorksTitle}</h2>

    <div class="how-it-works__media">
      <!-- TODO: replace with real gameplay video once CEO provides webm/mp4
           (see GameplayVideo component). Using placeholder for now. -->
      <Placeholder
        width={1200}
        height={675}
        text="Gameplay"
        variant="surface"
        alt="Gameplay grid showing successful and failed steps as the player discovers a rule"
      />
    </div>

    <p class="how-it-works__body">{strings.landing.howItWorksBody}</p>
  </div>
</section>

<style>
  .how-it-works__title {
    text-align: center;
    max-width: 24ch;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .how-it-works__media {
    margin-inline: auto;
    max-width: 900px;
    margin-bottom: var(--space-8);
  }

  .how-it-works__body {
    max-width: 60ch;
    margin-inline: auto;
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-lead);
  }
</style>
