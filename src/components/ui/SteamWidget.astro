---
/**
 * SteamWidget — embeds the official Steam store widget for AppID 4627790.
 *
 * Behaviour: browsers lazy-load third-party iframes; the widget renders
 * after the user clicks to activate it (standard browser privacy behaviour).
 *
 * Usage: drop <SteamWidget /> anywhere a Steam presence confirmation is
 * contextually useful (e.g. Press Kit page). Avoid on pages that already
 * have a direct CTA button pointing to Steam.
 */
---
<div class="steam-widget">
  <iframe
    src="https://store.steampowered.com/widget/4627790/"
    width="646"
    height="190"
    frameborder="0"
    title="Don't Step Wrong 2 on Steam"
    loading="lazy"
  ></iframe>
</div>

<style>
  .steam-widget {
    display: flex;
    justify-content: center;
    overflow-x: auto;           /* mobile: scroll horizontal em vez de quebrar layout */
    background-color: var(--color-muted);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    width: 100%;
  }
</style>
