---
import type { Locale } from '@i18n/utils';
import { t, getUrl } from '@i18n/utils';
import CTADiscord from '@components/ui/CTADiscord.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);

const year = new Date().getFullYear();
---
<footer role="contentinfo" class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <img
        src="/images/logo-1280-x-720.png"
        alt="Don't Step Wrong 2"
        class="footer__logo-img"
        width="1280"
        height="720"
        loading="lazy"
        decoding="async"
      />
    </div>

    <nav class="footer__nav" aria-label="Footer navigation">
      <ul>
        <li><a href={getUrl('home',      locale)}>{strings.nav.home}</a></li>
        <li><a href={getUrl('mechanics', locale)}>{strings.nav.mechanics}</a></li>
        <li><a href={getUrl('devlog',    locale)}>{strings.nav.devlog}</a></li>
        <li><a href={getUrl('presskit',  locale)}>{strings.nav.presskit}</a></li>
        <li><a href={getUrl('privacy',   locale)}>{strings.nav.privacy}</a></li>
        <li><a href={getUrl('credits',   locale)}>{strings.nav.credits}</a></li>
      </ul>
    </nav>

    <div class="footer__social">
      <CTADiscord label={strings.cta.followDevelopment} />
      <a
        href="https://adrianocastro.itch.io/dont-step-wrong"
        target="_blank"
        rel="noopener noreferrer"
        class="footer__social-link"
      >
        itch.io <span aria-hidden="true">↗</span>
      </a>
      <a
        href="https://store.steampowered.com/app/4627790/Dont_Step_Wrong_2/"
        target="_blank"
        rel="noopener noreferrer"
        class="footer__social-link"
      >
        Steam <span aria-hidden="true">↗</span>
      </a>
    </div>

    <div class="footer__meta">
      <p>© {year} {strings.meta.studio}. {strings.footer.rights}</p>
      <p>
        <a href={getUrl('credits', locale)} class="footer__credit-link">{strings.footer.assetsCredit}</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-alt);
    border-top: 1px solid var(--color-muted);
    padding-block: var(--space-12);
  }

  .footer__inner {
    display: grid;
    gap: var(--space-8);
  }

  .footer__logo-img {
    height: 48px;
    width: auto;
    display: block;
  }

  .footer__nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-6);
  }

  .footer__nav a {
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .footer__nav a:hover {
    color: var(--color-text);
  }

  .footer__social {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }

  .footer__social-link {
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: var(--color-text-muted);
    padding: var(--space-2) var(--space-3);
    transition: color var(--transition-fast);
  }

  .footer__social-link:hover {
    color: var(--color-brand);
  }

  .footer__meta {
    display: grid;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-muted);
    padding-top: var(--space-6);
  }

  .footer__credit-link {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__credit-link:hover {
    color: var(--color-text);
  }
</style>
