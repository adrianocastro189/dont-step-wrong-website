---
import type { Locale } from '@i18n/utils';
import { t, getAlternateURLs, toAbsolute, getUrl } from '@i18n/utils';
import BaseLayout from '@components/layout/BaseLayout.astro';
import SchemaBreadcrumb from '@components/seo/SchemaBreadcrumb.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);

const seo: Record<Locale, { title: string; description: string }> = {
  en: {
    title: "Press Kit — Don't Step Wrong 2",
    description: 'Assets, screenshots, description and contact for press and Steam curators covering Don\'t Step Wrong 2.',
  },
  pt: {
    title: "Press Kit — Don't Step Wrong 2",
    description: 'Assets, screenshots, descrição e contato para imprensa e curadores Steam cobrindo Don\'t Step Wrong 2.',
  },
  es: {
    title: "Press Kit — Don't Step Wrong 2",
    description: 'Assets, capturas, descripción y contacto para prensa y curadores Steam cubriendo Don\'t Step Wrong 2.',
  },
};

const alternates = getAlternateURLs('presskit');
const canonicalURL = toAbsolute(alternates[locale]);
const { title, description } = seo[locale];

const breadcrumb = [
  { name: strings.nav.home, url: getUrl('home', locale) },
  { name: strings.nav.presskit, url: getUrl('presskit', locale) },
];

const CONTACT_EMAIL = 'press@feriado.studio'; // TODO: confirm with CEO

const about: Record<Locale, { p1: string; p2: string }> = {
  en: {
    p1: "Don't Step Wrong 2 is a grid-based puzzle game where each level contains an implicit rule. The player navigates from a starting block to an exit, stepping only on blocks that satisfy the rule. The rule is never stated, displayed, or hinted at. Discovery happens through repeated attempts: step on a wrong block, observe the result, and update your hypothesis.",
    p2: "The game spans 10 distinct zones, each with a different visual palette and rule categories. Rule categories include numeric patterns, word-based logic, and time-based constraints, among others. Players can equip optional skills before each level that provide targeted assistance without revealing the rule. Skills are selected per level with no permanent loadout.",
  },
  pt: {
    p1: "Don't Step Wrong 2 é um puzzle em grade onde cada fase contém uma regra implícita. O jogador navega de um bloco inicial até a saída, pisando apenas nos blocos que satisfazem a regra. A regra nunca é declarada, exibida ou indicada. A descoberta acontece por tentativas repetidas: pise em um bloco errado, observe o resultado e atualize sua hipótese.",
    p2: "O jogo abrange 10 zonas distintas, cada uma com uma paleta visual diferente e categorias de regra. As categorias incluem padrões numéricos, lógica baseada em palavras e restrições temporais, entre outras. Os jogadores podem equipar habilidades opcionais antes de cada fase que oferecem assistência pontual sem revelar a regra. As habilidades são selecionadas por fase, sem loadout permanente.",
  },
  es: {
    p1: "Don't Step Wrong 2 es un puzzle en cuadrícula donde cada nivel contiene una regla implícita. El jugador navega desde un bloque inicial hasta la salida, pisando solo los bloques que satisfacen la regla. La regla nunca se enuncia, muestra ni insinúa. El descubrimiento ocurre a través de intentos repetidos: pisa un bloque incorrecto, observa el resultado y actualiza tu hipótesis.",
    p2: "El juego abarca 10 zonas distintas, cada una con una paleta visual diferente y categorías de reglas. Las categorías incluyen patrones numéricos, lógica basada en palabras y restricciones temporales, entre otras. Los jugadores pueden equipar habilidades opcionales antes de cada nivel que ofrecen asistencia puntual sin revelar la regla. Las habilidades se eligen por nivel, sin carga permanente.",
  },
};

const features: Record<Locale, string[]> = {
  en: [
    'Grid-based puzzle game: reach the exit by stepping only on valid blocks',
    'Each level has an implicit rule, never named or displayed by the game',
    'Discovery through trial and error, with no hints, tutorial, or explanation',
    '10 distinct zones with different visual palettes and rule categories',
    'Rule categories include numeric, word-based, and time-based types, among others',
    '8 optional skills (active and passive) that assist without solving the puzzle',
    'Skills are chosen per level, with no permanent loadout',
    'Multilingual: English, Portuguese (pt-BR), Spanish',
    'Solo indie production by Feriado studio',
    'Free demo available on Steam',
  ],
  pt: [
    'Puzzle em grade: chegue à saída pisando apenas nos blocos válidos',
    'Cada fase tem uma regra implícita, nunca nomeada ou exibida pelo jogo',
    'Descoberta por tentativa e erro, sem dicas, tutorial ou explicação',
    '10 zonas distintas com paletas visuais e categorias de regra diferentes',
    'As categorias incluem tipos numéricos, baseados em palavras e temporais, entre outros',
    '8 habilidades opcionais (ativas e passivas) que auxiliam sem resolver o puzzle',
    'Habilidades escolhidas por fase, sem loadout permanente',
    'Multilíngue: inglês, português (pt-BR), espanhol',
    'Produção indie solo pelo estúdio Feriado',
    'Demo gratuita disponível na Steam',
  ],
  es: [
    'Puzzle en cuadrícula: llega a la salida pisando solo los bloques válidos',
    'Cada nivel tiene una regla implícita, nunca nombrada ni mostrada por el juego',
    'Descubrimiento por prueba y error, sin pistas, tutorial ni explicación',
    '10 zonas distintas con paletas visuales y categorías de reglas diferentes',
    'Las categorías incluyen tipos numéricos, basados en palabras y temporales, entre otros',
    '8 habilidades opcionales (activas y pasivas) que ayudan sin resolver el puzzle',
    'Habilidades elegidas por nivel, sin carga permanente',
    'Multilingüe: inglés, portugués (pt-BR), español',
    'Producción indie en solitario por el estudio Feriado',
    'Demo gratuita disponible en Steam',
  ],
};
---
<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  hreflang={alternates}
  locale={locale}
  currentPage="presskit"
>
  <SchemaBreadcrumb slot="head" items={breadcrumb} />

  <section class="section">
    <div class="container-prose">
      <h1>{strings.presskit.h1}</h1>
    </div>
  </section>

  <section class="section">
    <div class="container-prose presskit">
      <div class="presskit__block">
        <h2>{strings.presskit.aboutTitle}</h2>
        <dl class="presskit__facts">
          <dt>Title</dt>
          <dd>Don't Step Wrong 2</dd>
          <dt>Developer</dt>
          <dd>Feriado (Adriano Castro)</dd>
          <dt>Platform</dt>
          <dd>PC (Steam)</dd>
          <dt>Release</dt>
          <dd>2026 (TBA) — Demo: June 2026</dd>
          <dt>Genre</dt>
          <dd>Puzzle, Rule Discovery, Indie</dd>
          <dt>Steam</dt>
          <dd>
            <a href="https://store.steampowered.com/app/4627790/Dont_Step_Wrong_2/"
               target="_blank" rel="noopener noreferrer">
              store.steampowered.com/app/4627790
            </a>
          </dd>
          <dt>Discord</dt>
          <dd>
            <a href="https://discord.gg/KX8mzVuqzm"
               target="_blank" rel="noopener noreferrer">
              discord.gg/KX8mzVuqzm
            </a>
          </dd>
        </dl>
        <p class="presskit__lead">{about[locale].p1}</p>
        <p class="presskit__lead">{about[locale].p2}</p>
      </div>

      <div class="presskit__block">
        <h2>{strings.presskit.featuresTitle}</h2>
        <ul class="presskit__features">
          {features[locale].map((f) => <li>{f}</li>)}
        </ul>
      </div>

      <div class="presskit__block">
        <h2>{strings.presskit.assetsTitle}</h2>
        <ul class="presskit__assets">
          <!-- TODO: CEO — provide final asset URLs (currently pointing to public folder placeholders) -->
          <li>
            <span>Logo (PNG)</span>
            <a href="/press/logo.png" download>{strings.presskit.download}</a>
          </li>
          <li>
            <span>Steam capsule</span>
            <a href="/press/capsule.png" download>{strings.presskit.download}</a>
          </li>
          <li>
            <span>Screenshots (ZIP)</span>
            <a href="/press/screenshots.zip" download>{strings.presskit.download}</a>
          </li>
          <li>
            <span>Gameplay GIF</span>
            <a href="/press/gameplay.mp4" download>{strings.presskit.download}</a>
          </li>
        </ul>
      </div>

      <div class="presskit__block">
        <h2>{strings.presskit.contactTitle}</h2>
        <p>
          <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .presskit {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .presskit__block h2 {
    margin-bottom: var(--space-4);
  }

  .presskit__lead {
    margin-top: var(--space-4);
    color: var(--color-text);
  }

  .presskit__facts {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-2) var(--space-6);
    margin-bottom: var(--space-4);
  }

  .presskit__facts dt {
    font-weight: var(--weight-bold);
    color: var(--color-text-muted);
  }

  .presskit__facts dd {
    color: var(--color-text);
  }

  .presskit__features {
    list-style: disc;
    padding-left: var(--space-6);
    color: var(--color-text);
  }

  .presskit__features li {
    margin-bottom: var(--space-2);
  }

  .presskit__assets {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .presskit__assets li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    border: var(--border-width) solid var(--border-color);
    border-radius: var(--radius-md);
  }

  .presskit__assets a {
    color: var(--color-brand);
    font-weight: var(--weight-bold);
  }

  .presskit__assets a:hover {
    color: var(--color-brand-hover);
  }
</style>
