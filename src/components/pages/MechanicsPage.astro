---
import type { Locale } from '@i18n/utils';
import { t, getAlternateURLs, toAbsolute, getUrl } from '@i18n/utils';
import BaseLayout from '@components/layout/BaseLayout.astro';
import SchemaBreadcrumb from '@components/seo/SchemaBreadcrumb.astro';
import CTASteam from '@components/ui/CTASteam.astro';
import BiomeCarousel from '@components/ui/BiomeCarousel.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);

const seo: Record<Locale, { title: string; description: string }> = {
  en: {
    title: "Mechanics — Don't Step Wrong 2",
    description: 'Skills, zones and rule categories in Don\'t Step Wrong 2. Systems explained — rules kept secret.',
  },
  pt: {
    title: "Mecânicas — Don't Step Wrong 2",
    description: 'Habilidades, zonas e categorias de regras em Don\'t Step Wrong 2. Sistemas explicados — regras mantidas em segredo.',
  },
  es: {
    title: "Mecánicas — Don't Step Wrong 2",
    description: 'Habilidades, zonas y categorías de reglas en Don\'t Step Wrong 2. Sistemas explicados — reglas mantenidas en secreto.',
  },
};

const alternates = getAlternateURLs('mechanics');
const canonicalURL = toAbsolute(alternates[locale]);
const { title, description } = seo[locale];

const breadcrumb = [
  { name: strings.nav.home, url: getUrl('home', locale) },
  { name: strings.nav.mechanics, url: getUrl('mechanics', locale) },
];

const m = strings.mechanics;

const ruleCards = [
  { title: m.ruleNumericTitle, body: m.ruleNumericBody },
  { title: m.ruleWordsTitle,   body: m.ruleWordsBody },
  { title: m.ruleTimeTitle,    body: m.ruleTimeBody },
  { title: m.ruleMoreTitle,    body: m.ruleMoreBody },
];

type SkillType = 'active' | 'passive';

const skills: Array<{ name: string; desc: string; type: SkillType }> = [
  { name: 'Spider Sense',     desc: m.skillSpiderSenseDesc, type: 'active' },
  { name: 'Breadcrumb Trail', desc: m.skillBreadcrumbDesc,  type: 'active' },
  { name: 'Safe Start',       desc: m.skillSafeStartDesc,   type: 'active' },
  { name: 'Dead End Sense',   desc: m.skillDeadEndDesc,     type: 'active' },
  { name: 'Hint Reveal',      desc: m.skillHintRevealDesc,  type: 'active' },
  { name: 'Super Jump',       desc: m.skillSuperJumpDesc,   type: 'active' },
  { name: 'Freezer',          desc: m.skillFreezerDesc,     type: 'passive' },
  { name: 'Farmer',           desc: m.skillFarmerDesc,      type: 'passive' },
];

const biomes: Array<{ name: string; desc: string }> = [
  { name: 'Green Forest',   desc: m.biomeGreenForestDesc },
  { name: 'Blue Forest',    desc: m.biomeBlueForestDesc },
  { name: 'River Crossing', desc: m.biomeRiverCrossingDesc },
  { name: 'Swamp',          desc: m.biomeSwampDesc },
  { name: 'Ruins',          desc: m.biomeRuinsDesc },
  { name: 'Rocky Desert',   desc: m.biomeRockyDesertDesc },
  { name: 'Sandy Desert',   desc: m.biomeSandyDesertDesc },
  { name: 'Snow Mountain',  desc: m.biomeSnowMountainDesc },
  { name: 'Rocky Mountain', desc: m.biomeRockyMountainDesc },
  { name: 'Volcano',        desc: m.biomeVolcanoDesc },
];
---
<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  hreflang={alternates}
  locale={locale}
  currentPage="mechanics"
>
  <SchemaBreadcrumb slot="head" items={breadcrumb} />

  <section class="section">
    <div class="container-prose">
      <h1>{m.h1}</h1>
      <p class="lead">{m.lead}</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">{m.rulesTitle}</h2>
      <div class="cards-grid cards-grid--4">
        {ruleCards.map((card) => (
          <article class="mechanic-card">
            <h3 class="mechanic-card__title">{card.title}</h3>
            <p class="mechanic-card__body">{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">{m.skillsTitle}</h2>
      <p class="section-lead">{m.skillsLead}</p>
      <div class="cards-grid cards-grid--2">
        {skills.map((skill) => (
          <article class="skill-card">
            <div class="skill-card__header">
              <span class="skill-card__name">{skill.name}</span>
              <span class={`skill-card__badge skill-card__badge--${skill.type}`}>
                {skill.type === 'active' ? m.skillLabelActive : m.skillLabelPassive}
              </span>
            </div>
            <p class="skill-card__desc">{skill.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">{m.biomesTitle}</h2>
      <BiomeCarousel biomes={biomes} />
    </div>
  </section>

  <section class="section">
    <div class="container final-cta-inline">
      <h2>{m.soundsInteresting}</h2>
      <CTASteam label={strings.cta.playDemo} target="demo" variant="primary" />
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-size: var(--text-lead);
    color: var(--color-text-muted);
    margin-top: var(--space-6);
  }

  .section-title {
    margin-bottom: var(--space-8);
  }

  .section-lead {
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    margin-top: calc(var(--space-8) * -1);
  }

  /* --- Shared grid --- */

  .cards-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .cards-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .cards-grid--3 {
      grid-template-columns: repeat(3, 1fr);
    }

    .cards-grid--4 {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* --- Rule type cards --- */

  .mechanic-card {
    background-color: var(--color-bg);
    border: var(--border-width) solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mechanic-card__title {
    color: var(--color-text);
    font-size: var(--text-body);
    font-weight: var(--weight-bold);
  }

  .mechanic-card__body {
    color: var(--color-text-muted);
    font-size: var(--text-body);
  }

  /* --- Skill cards --- */

  .skill-card {
    background-color: var(--color-bg);
    border: var(--border-width) solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color var(--transition-fast);
  }

  .skill-card:hover {
    border-color: var(--color-brand);
  }

  .skill-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .skill-card__name {
    font-weight: var(--weight-bold);
    color: var(--color-text);
  }

  .skill-card__badge {
    font-size: 0.75rem;
    font-weight: var(--weight-bold);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .skill-card__badge--active {
    background-color: rgba(242, 166, 42, 0.15);
    color: var(--color-brand-active);
  }

  .skill-card__badge--passive {
    background-color: rgba(107, 91, 74, 0.12);
    color: var(--color-text-muted);
  }

  .skill-card__desc {
    color: var(--color-text-muted);
    font-size: var(--text-body);
  }

  /* --- Final CTA --- */

  .final-cta-inline {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    text-align: center;
  }
</style>
