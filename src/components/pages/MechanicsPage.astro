---
import type { Locale } from '@i18n/utils';
import { t, getAlternateURLs, toAbsolute, getUrl } from '@i18n/utils';
import BaseLayout from '@components/layout/BaseLayout.astro';
import SchemaBreadcrumb from '@components/seo/SchemaBreadcrumb.astro';
import CTASteam from '@components/ui/CTASteam.astro';
import BiomeCarousel from '@components/ui/BiomeCarousel.astro';
import Icon from '@components/ui/Icon.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);

const seo: Record<Locale, { title: string; description: string }> = {
  en: {
    title: "Mechanics - Don't Step Wrong 2",
    description: 'Skills, items, zones and rule categories in Don\'t Step Wrong 2. Systems explained, rules kept secret.',
  },
  pt: {
    title: "Mecânicas - Don't Step Wrong 2",
    description: 'Habilidades, itens, zonas e categorias de regras em Don\'t Step Wrong 2. Sistemas explicados, regras mantidas em segredo.',
  },
  es: {
    title: "Mecánicas - Don't Step Wrong 2",
    description: 'Habilidades, ítems, zonas y categorías de reglas en Don\'t Step Wrong 2. Sistemas explicados, reglas mantenidas en secreto.',
  },
};

const alternates = getAlternateURLs('mechanics');
const canonicalURL = toAbsolute(alternates[locale]);
const { title, description } = seo[locale];

const breadcrumb = [
  { name: strings.nav.home, url: getUrl('home', locale) },
  { name: strings.nav.mechanics, url: getUrl('mechanics', locale) },
];

const m = strings.mechanics;

const ruleCards = [
  { title: m.ruleNumericTitle, body: m.ruleNumericBody },
  { title: m.ruleWordsTitle,   body: m.ruleWordsBody },
  { title: m.ruleTimeTitle,    body: m.ruleTimeBody },
  { title: m.ruleMoreTitle,    body: m.ruleMoreBody },
];

const skills = [
  { name: m.skillSpiderSenseName,  desc: m.skillSpiderSenseDesc,  icon: 27 },
  { name: m.skillBreadcrumbName,   desc: m.skillBreadcrumbDesc,   icon: 28 },
  { name: m.skillSafeStartName,    desc: m.skillSafeStartDesc,    icon: 26 },
  { name: m.skillDeadEndName,      desc: m.skillDeadEndDesc,      icon: 29 },
  { name: m.skillSuperJumpName,    desc: m.skillSuperJumpDesc,    icon: 24 },
  { name: m.skillFarmerName,       desc: m.skillFarmerDesc,       icon:  0 },
  { name: m.skillFreezerName,      desc: m.skillFreezerDesc,      icon:  3 },
];

const items = [
  { name: m.itemRevealAchievementName, desc: m.itemRevealAchievementDesc, icon:  5 },
  { name: m.itemDoubleBlocksName,      desc: m.itemDoubleBlocksDesc,      icon:  0 },
  { name: m.itemHintUnlockName,        desc: m.itemHintUnlockDesc,        icon:  1 },
  { name: m.itemBoardLockName,         desc: m.itemBoardLockDesc,         icon:  3 },
  { name: m.itemValidBlockName,        desc: m.itemValidBlockDesc,        icon:  8 },
  { name: m.itemRulesRevealName,       desc: m.itemRulesRevealDesc,       icon: 10 },
];

const achievementCategories = [
  { name: m.achievementSpeedName,     desc: m.achievementSpeedDesc,     icon: 11 },
  { name: m.achievementZonesName,     desc: m.achievementZonesDesc,     icon: 14 },
  { name: m.achievementStepsName,     desc: m.achievementStepsDesc,     icon:  8 },
  { name: m.achievementCurrencyName,  desc: m.achievementCurrencyDesc,  icon:  6 },
  { name: m.achievementShopName,      desc: m.achievementShopDesc,      icon: 25 },
  { name: m.achievementEnduranceName, desc: m.achievementEnduranceDesc, icon:  9 },
  { name: m.achievementMomentsName,   desc: m.achievementMomentsDesc,   icon: 23 },
];

const biomes: Array<{ name: string; desc: string; image?: string }> = [
  { name: 'Green Forest',   desc: m.biomeGreenForestDesc,   image: '/images/zones/green-forest.png' },
  { name: 'Blue Forest',    desc: m.biomeBlueForestDesc,    image: '/images/zones/blue-forest.png' },
  { name: 'River Crossing', desc: m.biomeRiverCrossingDesc, image: '/images/zones/river.png' },
  { name: 'Swamp',          desc: m.biomeSwampDesc },
  { name: 'Ruins',          desc: m.biomeRuinsDesc },
  { name: 'Rocky Desert',   desc: m.biomeRockyDesertDesc },
  { name: 'Sandy Desert',   desc: m.biomeSandyDesertDesc },
  { name: 'Snow Mountain',  desc: m.biomeSnowMountainDesc },
  { name: 'Rocky Mountain', desc: m.biomeRockyMountainDesc },
  { name: 'Volcano',        desc: m.biomeVolcanoDesc },
];
---
<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  hreflang={alternates}
  locale={locale}
  currentPage="mechanics"
>
  <SchemaBreadcrumb slot="head" items={breadcrumb} />

  <!-- Intro -->
  <section class="section">
    <div class="container-prose">
      <h1>{m.h1}</h1>
      <p class="lead">{m.lead}</p>
    </div>
  </section>

  <!-- Rule Types -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">{m.rulesTitle}</h2>
      <p class="section-lead">{m.rulesLead}</p>
      <div class="cards-grid cards-grid--4">
        {ruleCards.map((card) => (
          <article class="mechanic-card">
            <h3 class="mechanic-card__title">{card.title}</h3>
            <p class="mechanic-card__body">{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">{m.skillsTitle}</h2>
      <p class="section-lead">{m.skillsLead}</p>
      <div class="cards-grid cards-grid--2">
        {skills.map((skill) => (
          <article class="item-card">
            <Icon index={skill.icon} size={100} class="item-card__icon-side" />
            <div class="item-card__body">
              <div class="item-card__header">
                <span class="item-card__name">{skill.name}</span>
                <span class="item-card__badge item-card__badge--permanent">
                  {m.skillLabelPermanent}
                </span>
              </div>
              <p class="item-card__desc">{skill.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Items -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">{m.itemsTitle}</h2>
      <p class="section-lead">{m.itemsLead}</p>
      <div class="cards-grid cards-grid--2">
        {items.map((item) => (
          <article class="item-card">
            <Icon index={item.icon} size={100} class="item-card__icon-side" />
            <div class="item-card__body">
              <div class="item-card__header">
                <span class="item-card__name">{item.name}</span>
                <span class="item-card__badge item-card__badge--single-use">
                  {m.skillLabelSingleUse}
                </span>
              </div>
              <p class="item-card__desc">{item.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Zones -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">{m.zonesTitle}</h2>
      <p class="section-lead">{m.zonesLead}</p>
      <BiomeCarousel biomes={biomes} comingSoonText={m.biomeComingSoon} />
    </div>
  </section>

  <!-- Achievements -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">{m.achievementsTitle}</h2>
      <p class="section-lead">{m.achievementsLead}</p>
      <div class="cards-grid cards-grid--achievements">
        {achievementCategories.map((cat) => (
          <article class="achievement-card">
            <Icon index={cat.icon} size={90} class="achievement-card__icon-side" />
            <div class="achievement-card__body">
              <h3 class="achievement-card__name">{cat.name}</h3>
              <p class="achievement-card__desc">{cat.desc}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="achievements-more">{m.achievementsMore}</p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section">
    <div class="container final-cta-inline">
      <h2>{m.soundsInteresting}</h2>
      <CTASteam label={strings.cta.playDemo} target="demo" variant="primary" />
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-size: var(--text-lead);
    color: var(--color-text-muted);
    margin-top: var(--space-6);
  }

  .section-title {
    margin-bottom: var(--space-4);
  }

  .section-lead {
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  /* --- Shared grid --- */

  .cards-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .cards-grid--4 {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .cards-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }

    .cards-grid--achievements {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .cards-grid--achievements {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* --- Rule type cards --- */

  .mechanic-card {
    background-color: var(--color-bg);
    border: var(--border-width) solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mechanic-card__title {
    color: var(--color-text);
    font-size: var(--text-body);
    font-weight: var(--weight-bold);
  }

  .mechanic-card__body {
    color: var(--color-text-muted);
    font-size: var(--text-body);
  }

  /* --- Skill / Item cards (shared layout) --- */

  .item-card {
    background-color: var(--color-bg);
    border: var(--border-width) solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-6);
    transition: border-color var(--transition-fast);
    position: relative;
    overflow: hidden;
  }

  .item-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(242, 166, 42, 0.20) 0%, transparent 38%);
    pointer-events: none;
    z-index: 0;
  }

  :global(.item-card__icon-side) {
    flex-shrink: 0;
    opacity: 0.55;
    filter: brightness(0);
    position: relative;
    z-index: 1;
  }

  .item-card:hover {
    border-color: var(--color-brand);
  }

  .item-card__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: relative;
    z-index: 1;
  }

  .item-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .item-card__name {
    font-weight: var(--weight-bold);
    color: var(--color-text);
  }

  .item-card__badge {
    font-size: 0.75rem;
    font-weight: var(--weight-bold);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .item-card__badge--permanent {
    background-color: rgba(242, 166, 42, 0.15);
    color: var(--color-brand-active);
  }

  .item-card__badge--single-use {
    background-color: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .item-card__desc {
    color: var(--color-text-muted);
    font-size: var(--text-body);
  }

  /* --- Achievement cards --- */

  .achievement-card {
    background-color: var(--color-bg);
    border: var(--border-width) solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-6);
    transition: border-color var(--transition-fast);
    position: relative;
    overflow: hidden;
  }

  .achievement-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(242, 166, 42, 0.20) 0%, transparent 38%);
    pointer-events: none;
    z-index: 0;
  }

  :global(.achievement-card__icon-side) {
    flex-shrink: 0;
    opacity: 0.55;
    filter: brightness(0);
    position: relative;
    z-index: 1;
  }

  .achievement-card:hover {
    border-color: var(--color-brand);
  }

  .achievement-card__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    position: relative;
    z-index: 1;
  }

  .achievement-card__name {
    color: var(--color-text);
    font-size: var(--text-body);
    font-weight: var(--weight-bold);
  }

  .achievement-card__desc {
    color: var(--color-text-muted);
    font-size: var(--text-body);
  }

.achievements-more {
    margin-top: var(--space-8);
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* --- Final CTA --- */

  .final-cta-inline {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    text-align: center;
  }
</style>
